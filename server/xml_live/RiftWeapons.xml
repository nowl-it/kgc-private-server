<!-- xml 정보
	ID 사용 범위 : 10000 ~ 16999
	ID 규칙 : 
		(1) 1x000 : 대상 클래스 (0 ~ 5)
		(3) 10xxx : 인덱스 (000 ~ 999)
		
	필드 구성 :
		(1) <ID>
		(2) <Comment> (not used)
		(3) <Name> (default : TreasureName_{ID})
		(4) <Desc> (default : TreasureDesc_{ID})
		(5) <ItemRecipe> : 아이템 조합 레시피
		(6) <ResultItemID> : 조합 성공 시 제작되는 아이템 ID (Items.xml)
		(7) <Role> (default : None)
		(8) <Prefab> (default : RiftWeaponPrefab_{ID})
		(8) <MinVersion>
		
-->
<RiftWeapons>
