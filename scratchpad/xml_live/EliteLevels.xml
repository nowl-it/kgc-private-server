<EliteLevels>
	<EliteLevel ID="300051">
		<Type>EventTrigger</Type>
		<Desc>Vegita, what does scouter say about his power level?                     It's over {Value}!!!!</Desc>
		<MaxLevel>5</MaxLevel>
		<!-- 1레벨 올리는데 필요한 포인트의 양(예: 적 성급 n성 증가 도전) -->
		<LevelRatio>1</LevelRatio>
		<!-- 적용할 이벤트 트리거 -->
		<!-- 해당 이벤트 트리거에 들어있는 버프데이터에 ValueRatio 계수를 곱해준 뒤 실제 인게임에 적용함 -->
		<EventTrigger>0</EventTrigger>
		
		<!-- ValueRatio, RewardRatio를 레벨마다 각각 설정해주고 싶을 경우 LevelDatas에 MaxLevel만큼 레벨 순서대로 넣어주면 됨 -->
		<LevelDatas>
			<LevelData ValueRatio="0" RewardRatio="0"/>
			<LevelData ValueRatio="1800" RewardRatio="30"/>
			<LevelData ValueRatio="3600" RewardRatio="60"/>
			<LevelData ValueRatio="5400" RewardRatio="90"/>
			<LevelData ValueRatio="7200" RewardRatio="120"/>
			<LevelData ValueRatio="9000" RewardRatio="150"/>
		</LevelDatas>
	</EliteLevel>
	
